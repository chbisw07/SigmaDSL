# v1.1-B: runtime option context binding examples.
#
# Notes:
# - `option.iv` is a ratio (0.25 == 25%).
# - the runner enforces explicit data quality (`data_is_fresh` and `quality_flags`).

rule "OPT: High IV" in option:
    when data.is_fresh and option.iv > 20%:
        then emit_signal(kind="HIGH_IV", reason="iv_gt_20pct")

rule "OPT: Delta Strong" in option:
    when data.is_fresh and option.delta > 0.6:
        then annotate(note="delta_gt_0_6")

